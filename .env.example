# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...              # Required for LLM inference and fine-tuning
FINE_TUNED_MODEL_ID=               # Optional: your fine-tuned model ID (ft:gpt-4o-mini:...)

# ── Model Configuration ───────────────────────────────────────────────────────
MODEL_NAME=gpt-4o-mini
FEW_SHOT=true

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns         # Local: mlruns  |  Remote: http://mlflow:5000

# ── API Server ────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
PORT=8000

# ── Hugging Face Deployment ───────────────────────────────────────────────────
HF_TOKEN=hf_...
HF_SPACE=your-username/traffic-intersection

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
